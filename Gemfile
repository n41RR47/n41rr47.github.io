source "https://rubygems.org"

# Usa una versión de Jekyll compatible con jekyll-theme-chirpy
gem "jekyll", "~> 4.3.3"

# Tema jekyll-theme-chirpy
gem "jekyll-theme-chirpy", "~> 7.2.4"

# Dependencias requeridas por jekyll-theme-chirpy (según su documentación)
gem "jekyll-paginate"
gem "jekyll-seo-tag"
gem "jekyll-archives"
gem "jekyll-sitemap"

# Plugins adicionales
group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.12"
end

# Para evitar advertencias de Ruby 3.4.0/3.5.0
gem "logger"
gem "csv"
gem "ostruct"
gem "base64"

# Necesario para Ruby 3.x al usar jekyll serve
gem "webrick"
